{
  "name": "@shobman/strata-lint",
  "version": "0.1.0",
  "description": "ESLint plugin for the Strata layout protocol",
  "author": "Simon Hobman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shobman/strata.git",
    "directory": "packages/strata-lint"
  },
  "homepage": "https://github.com/shobman/strata/tree/main/packages/strata-lint",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "react",
    "layout",
    "slots",
    "architecture",
    "atomic-design"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@shobman/strata-cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  }
}
